# Land Finder — environment configuration
# Copy to .env.local for local dev, or set these as deploy-time secrets.

# ---- Auth ----
# Shared password protecting the whole app. If unset, auth is BYPASSED.
# Always set this in any deployment that is reachable on the internet.
LANDFINDER_AUTH_PASSWORD=
# Optional username (default: "team").
LANDFINDER_AUTH_USER=team

# ---- Ingestion ----
# Enable real ArcGIS REST ingestion. Without this, the connector uses the
# bundled Snohomish sample fixture (offline dev mode).
LANDFINDER_LIVE=0

# ArcGIS response cache controls. Cache lives on disk under data/cache/.
# Hours to keep cached responses (default 24). Set to 0 or unset to use default.
LANDFINDER_CACHE_TTL_HOURS=24
# Set to "0" to disable the cache (every request hits the network).
# LANDFINDER_CACHE=0
